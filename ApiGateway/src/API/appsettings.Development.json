{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "shop-route": {
        "ClusterId": "shop-cluster",
        "Match": {
          "Path": "/api/shop/{**catch-all}"
        }
      },
      "promotions-route": {
        "ClusterId": "promotions-cluster",
        "Match": {
          "Path": "/api/promotions/{**catch-all}"
        }
      },
      "products-route": {
        "ClusterId": "products-cluster",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        }
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "payments-route": {
        "ClusterId": "payments-cluster",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        }
      },
      "logs-route": {
        "ClusterId": "logs-cluster",
        "Match": {
          "Path": "/api/logs/{**catch-all}"
        }
      },
      "dashboard-route": {
        "ClusterId": "dashboard-cluster",
        "Match": {
          "Path": "/api/dashboard/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5294"
          }
        }
      },
      "users-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5300"
          }
        }
      },
      "shop-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5292"
          }
        }
      },
      "promotions-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5293"
          }
        }
      },
      "products-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5295"
          }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5297"
          }
        }
      },
      "payments-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5298"
          }
        }
      },
      "logs-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5299"
          }
        }
      },
      "dashboard-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5301"
          }
        }
      }
    }
  }
}
