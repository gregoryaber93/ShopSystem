{
  "ConnectionStrings": {
    "PostgreSql": "Host=localhost;Port=5432;Database=logger_service;Username=postgres;Password=postgres"
  },
  "MessageBrokers": {
    "KafkaConsumers": {
      "BootstrapServers": "localhost:9092",
      "GroupId": "logger-audit-v1",
      "Topics": [
        "orders.orderplaced.v1",
        "payments.paymentauthorized.v1",
        "payments.paymentfailed.v1",
        "promotions.pointsearned.v1",
        "promotions.pointsspent.v1",
        "promotions.loyaltyprofileupdated.v1"
      ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "LoggerService": {
    "BaseUrl": "http://localhost:5300"
  },
  "AllowedHosts": "*"
}
