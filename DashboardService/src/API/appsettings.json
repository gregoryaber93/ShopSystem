{
  "MessageBrokers": {
    "KafkaConsumers": {
      "BootstrapServers": "localhost:9092",
      "GroupId": "dashboard-projections-v1",
      "Topics": [
        "orders.orderplaced.v1",
        "payments.paymentauthorized.v1",
        "payments.paymentfailed.v1",
        "promotions.pointsearned.v1",
        "promotions.pointsspent.v1",
        "promotions.loyaltyprofileupdated.v1"
      ]
    }
  },
  "JwtRsa": {
    "Issuer": "ShopSystem.Auth",
    "Audience": "ShopSystem.Services",
    "TokenLifetimeMinutes": 30,
    "PublicKeyXml": "<RSAKeyValue><Modulus></Modulus><Exponent>AQAB</Exponent></RSAKeyValue>",
    "PrivateKeyXml": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
