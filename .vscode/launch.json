      "program": "${workspaceFolder}/AuthService/src/API/bin/Debug/net9.0/AuthService.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/AuthService/src/API",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5294"
      },
      "serverReadyAction": {
        "action": "openExternally",
